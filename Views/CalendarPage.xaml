<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HybridTrackerApp.Views.CalendarPage"
             Title="CalendarPage">
    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="dayLabel"  TargetType="Label">
                <!-- Explicit style - key defined, applies to checkInButtons -->
                <Setter Property="HorizontalTextAlignment" Value="Center" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>
    
    <VerticalStackLayout>
        <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
        <DatePicker>
            
        </DatePicker>
        <!-- Month picker -->
        <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,0,0,8">
            <Button Grid.Column="0" 
                    Text="&#9664;"  
                    FontSize="20" 
                    WidthRequest="50"/>
            <Label Grid.Column="1" 
                   Text="CurrentMonth" 
                   FontSize="20" 
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"/>
            <Button Grid.Column="2" 
                    Text="&#9654;"  
                    FontSize="20" 
                    WidthRequest="50"/>
        </Grid>
        
        <!-- Legend -->
        <FlexLayout JustifyContent="Center" Wrap="Wrap">
            <HorizontalStackLayout Margin="8,0">
                <BoxView Color="GreenYellow" 
                         WidthRequest="14" 
                         HeightRequest="14" 
                         CornerRadius="3" 
                         VerticalOptions="Center" />
                <Label Text=" Office" FontSize="12" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Margin="8,0">
                <BoxView Color="GhostWhite" 
                         WidthRequest="14" 
                         HeightRequest="14" 
                         CornerRadius="3" 
                         VerticalOptions="Center" />
                <Label Text=" Remote/OoO" FontSize="12" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
        </FlexLayout>
        
    <!-- days of the week -->
    <Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="4">
        <Label Grid.Column="0" Text="Mon" Style="{StaticResource dayLabel}" />
        <Label Grid.Column="1" Text="Tue" Style="{StaticResource dayLabel}" />
        <Label Grid.Column="2" Text="Wed" Style="{StaticResource dayLabel}" />
        <Label Grid.Column="3" Text="Thu" Style="{StaticResource dayLabel}" />
        <Label Grid.Column="4" Text="Fri" Style="{StaticResource dayLabel}" />
        <Label Grid.Column="5" Text="Sat" Style="{StaticResource dayLabel}" />
        <Label Grid.Column="6" Text="Sun" Style="{StaticResource dayLabel}" />
     </Grid>
    </VerticalStackLayout>
    

</ContentPage>