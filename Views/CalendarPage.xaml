<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HybridTrackerApp.Views.CalendarPage"
             xmlns:vm="clr-namespace:HybridTrackerApp.ViewModels"
             Title="Office Attendance Calendar"
             xmlns:controls="clr-namespace:Plugin.Maui.Calendar.Controls;assembly=Plugin.Maui.Calendar" 
             x:DataType="vm:CalendarViewModel">
    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="calendarLabel" TargetType="Label">
                <Setter Property="HorizontalTextAlignment" Value="Center" />
                <Setter Property="VerticalTextAlignment" Value="Center" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource Tertiary}" />
            </Style>
            <Style x:Key="hiddenLabel" TargetType="Label">
                <Setter Property="IsVisible" Value="False" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <VerticalStackLayout>

        <!-- Legend -->
        <FlexLayout JustifyContent="Center" Wrap="Wrap" Padding="20">
            <HorizontalStackLayout Margin="8,0">
                <BoxView Color="{StaticResource MidnightBlue}"
                         WidthRequest="14" 
                         HeightRequest="14" 
                         CornerRadius="3" 
                         VerticalOptions="Center" />
                <Label Text=" Office" FontSize="12" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Margin="8,0">
                <BoxView Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                         WidthRequest="14" 
                         HeightRequest="14" 
                         CornerRadius="3" 
                         VerticalOptions="Center" />
                <Label Text=" Remote/OoO" FontSize="12" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
        </FlexLayout>

        <Border StrokeShape="50" VerticalOptions="Fill">
            <controls:Calendar
                BackgroundColor="{StaticResource PrimaryDark}"
                VerticalOptions="Fill"
                HorizontalOptions="Fill"
                FirstDayOfWeek="Monday"
                SwipeUpToHideEnabled="False"
                
                EventIndicatorColor="{StaticResource Primary}"
                EventIndicatorTextColor="White"
                OtherMonthDayColor="Gray"
                TodayOutlineColor="{StaticResource Magenta}"
                SelectedTodayTextColor="{StaticResource Magenta}"

                MonthLabelStyle="{StaticResource calendarLabel}"
                YearLabelStyle="{StaticResource calendarLabel}"
                SelectedDateLabelStyle="{StaticResource hiddenLabel}"
                
                EventIndicatorType="Background"
                Events="{Binding Events}"
                DayTappedCommand="{Binding DayTappedCommand}"
                >
            </controls:Calendar>
        </Border>

    </VerticalStackLayout>
    
</ContentPage>